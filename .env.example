# Formspree endpoint for the waitlist form
# 1. Create a free account at https://formspree.io
# 2. Create a new form — you'll get a URL like https://formspree.io/f/xABCDEFG
# 3. Copy that URL here
# 4. In Vercel: Settings > Environment Variables > add this same key/value
PUBLIC_FORM_ACTION=https://formspree.io/f/YOUR_FORM_ID
