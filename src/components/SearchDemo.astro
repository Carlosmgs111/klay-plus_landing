---
import { getLocaleData } from '../i18n/t';
const en = getLocaleData('en');
const es = getLocaleData('es');

const results = [
  { file: 'policies/refund-policy.md', section: 'Chunk 14', match: 96, snippet: 'Full refunds are available within 30 days of purchase. After 30 days, a prorated refund may be issued based on remaining service period...' },
  { file: 'support/faq-billing.md', section: 'Chunk 7', match: 89, snippet: 'If a customer requests a refund, verify the purchase date and check whether the subscription falls under the standard or enterprise policy...' },
  { file: 'legal/terms-of-service.pdf', section: 'Chunk 42', match: 78, snippet: 'Refund eligibility is subject to the conditions outlined in Section 8.3. Chargebacks initiated without prior contact may result in account suspension...' },
];
---
<section class="py-24 px-6">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl sm:text-4xl font-bold text-text-primary text-center mb-16" data-reveal>
      <span data-lang-en>{en.search.title}</span>
      <span data-lang-es>{es.search.title}</span>
    </h2>

    <div class="animated-border p-8" data-reveal style="--reveal-delay: 0.1s;">
      <!-- Search input mockup -->
      <div class="flex items-center gap-3 mb-8 pb-6 border-b border-white/10">
        <svg class="w-5 h-5 text-accent-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <circle cx="11" cy="11" r="8" stroke-width="1.5"/>
          <path stroke-linecap="round" stroke-width="1.5" d="m21 21-4.35-4.35"/>
        </svg>
        <div class="text-text-primary text-sm">
          <span class="typing-text inline-block" data-lang-en>{en.search.query}</span>
          <span class="typing-text inline-block" data-lang-es>{es.search.query}</span>
        </div>
      </div>

      <!-- Results -->
      <div class="space-y-4">
        {results.map(({ file, section, match, snippet }, index) => (
          <div class="bg-white/[0.03] rounded-xl p-5 border border-white/5 hover:border-accent-primary/20 transition-colors" data-reveal style={`--reveal-delay: ${0.3 + index * 0.15}s`}>
            <div class="flex items-start justify-between gap-4 mb-2">
              <div>
                <span class="text-text-primary text-sm font-medium">{file}</span>
                <span class="text-text-muted text-xs ml-2">— {section}</span>
              </div>
              <span class={`text-xs font-bold px-2 py-0.5 rounded-full flex-shrink-0 ${
                match >= 95 ? 'bg-green-500/15 text-green-400' :
                match >= 90 ? 'bg-accent-primary/15 text-accent-tertiary' :
                'bg-amber-500/15 text-amber-400'
              }`} data-counter={match} data-counter-suffix="%">
                0%
              </span>
            </div>
            <p class="text-text-muted text-xs leading-relaxed">{snippet}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
