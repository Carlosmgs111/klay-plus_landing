---
import { getLocaleData } from '../i18n/t';
const en = getLocaleData('en');
const es = getLocaleData('es');

const formAction = import.meta.env.PUBLIC_FORM_ACTION || '#';
---
<section id="waitlist" class="py-24 px-6 relative overflow-hidden">
  <!-- Background glow orb -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[300px] bg-accent-primary/10 rounded-full blur-[128px]"></div>

  <div class="relative z-10 max-w-xl mx-auto">
    <div class="animated-border rounded-2xl p-12 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-text-primary mb-4" data-reveal>
        <span data-lang-en>{en.ctaFinal.headline}</span>
        <span data-lang-es>{es.ctaFinal.headline}</span>
      </h2>
      <p class="text-text-secondary mb-10" data-reveal style="--reveal-delay: 0.1s;">
        <span data-lang-en>{en.ctaFinal.subtitle}</span>
        <span data-lang-es>{es.ctaFinal.subtitle}</span>
      </p>

      <form action={formAction} method="POST" id="waitlist-form" class="flex flex-col gap-3 max-w-md mx-auto" data-reveal style="--reveal-delay: 0.2s;">
        <input
          type="email"
          name="email"
          required
          class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-text-primary text-sm placeholder:text-text-muted focus:outline-none focus:border-accent-primary/50 transition-colors"
          placeholder={en.ctaFinal.placeholder}
        />
        <div class="relative">
          <select
            name="use_case"
            required
            class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-accent-primary/50 transition-colors appearance-none cursor-pointer text-text-muted"
            id="use-case-select"
          >
            <option value="" disabled selected data-label-en={en.ctaFinal.useCaseDefault} data-label-es={es.ctaFinal.useCaseDefault}></option>
            <option value="support" data-label-en={en.ctaFinal.useCases.support} data-label-es={es.ctaFinal.useCases.support}></option>
            <option value="knowledge" data-label-en={en.ctaFinal.useCases.knowledge} data-label-es={es.ctaFinal.useCases.knowledge}></option>
            <option value="legal" data-label-en={en.ctaFinal.useCases.legal} data-label-es={es.ctaFinal.useCases.legal}></option>
            <option value="finance" data-label-en={en.ctaFinal.useCases.finance} data-label-es={es.ctaFinal.useCases.finance}></option>
            <option value="healthcare" data-label-en={en.ctaFinal.useCases.healthcare} data-label-es={es.ctaFinal.useCases.healthcare}></option>
            <option value="devtools" data-label-en={en.ctaFinal.useCases.devtools} data-label-es={es.ctaFinal.useCases.devtools}></option>
            <option value="ecommerce" data-label-en={en.ctaFinal.useCases.ecommerce} data-label-es={es.ctaFinal.useCases.ecommerce}></option>
            <option value="other" data-label-en={en.ctaFinal.useCases.other} data-label-es={es.ctaFinal.useCases.other}></option>
          </select>
          <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-text-muted pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </div>
        <textarea
          name="use_case_other"
          id="use-case-other"
          rows="2"
          class="hidden w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-text-primary text-sm placeholder:text-text-muted focus:outline-none focus:border-accent-primary/50 transition-colors resize-none"
          data-placeholder-en={en.ctaFinal.otherPlaceholder}
          data-placeholder-es={es.ctaFinal.otherPlaceholder}
        ></textarea>
        <button type="submit" id="waitlist-btn" class="w-full bg-gradient-to-r from-accent-primary to-accent-secondary text-white font-semibold px-6 py-3 rounded-lg hover:opacity-90 transition-opacity text-sm whitespace-nowrap" data-umami-event="Waitlist Form Submit">
          <span data-lang-en>{en.ctaFinal.button}</span>
          <span data-lang-es>{es.ctaFinal.button}</span>
        </button>
      </form>

      <!-- Toast -->
      <div id="toast" class="toast" role="alert"
        data-success-en={en.ctaFinal.toastSuccess}
        data-success-es={es.ctaFinal.toastSuccess}
        data-error-en={en.ctaFinal.toastError}
        data-error-es={es.ctaFinal.toastError}
        data-submitting-en={en.ctaFinal.submitting}
        data-submitting-es={es.ctaFinal.submitting}
        data-btn-en={en.ctaFinal.button}
        data-btn-es={es.ctaFinal.button}
      ></div>

      <p class="text-text-muted text-xs mt-4" data-reveal style="--reveal-delay: 0.3s;">
        <span data-lang-en>{en.ctaFinal.note}</span>
        <span data-lang-es>{es.ctaFinal.note}</span>
      </p>
    </div>
  </div>
</section>
