---
import '../styles/global.css';

interface Props {
  title?: string;
}
const { title = 'klay+ — RAG Infrastructure for AI Applications' } = Astro.props;
---
<!doctype html>
<html lang="en" data-lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Composable RAG infrastructure for development teams. Ingestion, chunking, embedding, and semantic retrieval — ready to plug into your AI stack." />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="Composable RAG infrastructure for development teams. Ingestion, chunking, embedding, and semantic retrieval — ready to plug into your AI stack." />
    <meta property="og:image" content="/og-image.png" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content="Composable RAG infrastructure for development teams. Ingestion, chunking, embedding, and semantic retrieval — ready to plug into your AI stack." />
    <meta name="twitter:image" content="/og-image.png" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="bg-bg-primary text-text-secondary font-sans antialiased overflow-x-hidden">
    <slot />
    <script>
      // Update select option labels and textarea placeholder for current language
      function updateSelectLang(lang) {
        document.querySelectorAll('#use-case-select option').forEach(function(opt) {
          var label = opt.getAttribute('data-label-' + lang);
          if (label) opt.textContent = label;
        });
        var otherTextarea = document.getElementById('use-case-other');
        if (otherTextarea) {
          var ph = otherTextarea.getAttribute('data-placeholder-' + lang);
          if (ph) otherTextarea.placeholder = ph;
        }
      }

      // Language toggle
      const savedLang = localStorage.getItem('klay-lang') || 'en';
      document.documentElement.setAttribute('data-lang', savedLang);
      updateSelectLang(savedLang);

      window.toggleLang = function() {
        const current = document.documentElement.getAttribute('data-lang');
        const next = current === 'en' ? 'es' : 'en';
        document.documentElement.setAttribute('data-lang', next);
        localStorage.setItem('klay-lang', next);
        updateSelectLang(next);
      };

      // Scroll reveal
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15 }
      );
      document.querySelectorAll('[data-reveal]').forEach((el) => observer.observe(el));

      // Counter animation
      const counterObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const el = entry.target;
            counterObserver.unobserve(el);

            const target = parseInt(el.getAttribute('data-counter'), 10);
            const suffix = el.getAttribute('data-counter-suffix') || '';
            const duration = 1200;
            const start = performance.now();

            function tick(now) {
              const t = Math.min((now - start) / duration, 1);
              const eased = 1 - Math.pow(1 - t, 3); // ease-out cubic
              el.textContent = Math.round(target * eased) + suffix;
              if (t < 1) requestAnimationFrame(tick);
            }
            requestAnimationFrame(tick);
          });
        },
        { threshold: 0.5 }
      );
      document.querySelectorAll('[data-counter]').forEach((el) => counterObserver.observe(el));

      // Use case select — update text color and toggle "other" textarea
      const useCaseSelect = document.getElementById('use-case-select');
      const otherTextarea = document.getElementById('use-case-other');
      if (useCaseSelect && otherTextarea) {
        useCaseSelect.addEventListener('change', function() {
          this.classList.remove('text-text-muted');
          this.classList.add('text-accent-tertiary');
          if (this.value === 'other') {
            otherTextarea.classList.remove('hidden');
            otherTextarea.required = true;
            otherTextarea.focus();
          } else {
            otherTextarea.classList.add('hidden');
            otherTextarea.required = false;
            otherTextarea.value = '';
          }
        });
      }

      // Waitlist form — AJAX submit with toast
      const waitlistForm = document.getElementById('waitlist-form');
      const toast = document.getElementById('toast');
      const submitBtn = document.getElementById('waitlist-btn');
      if (waitlistForm && toast && submitBtn) {
        function showToast(type) {
          const lang = document.documentElement.getAttribute('data-lang') || 'en';
          toast.textContent = toast.getAttribute('data-' + type + '-' + lang);
          toast.className = 'toast toast-' + type;
          setTimeout(function() {
            toast.classList.add('toast-hide');
          }, 4000);
        }

        waitlistForm.addEventListener('submit', function(e) {
          e.preventDefault();
          var lang = document.documentElement.getAttribute('data-lang') || 'en';
          var originalText = submitBtn.innerHTML;
          submitBtn.textContent = toast.getAttribute('data-submitting-' + lang);
          submitBtn.disabled = true;

          fetch(waitlistForm.action, {
            method: 'POST',
            body: new URLSearchParams(new FormData(waitlistForm)),
            headers: {
              'Accept': 'application/json',
              'Content-Type': 'application/x-www-form-urlencoded'
            }
          })
          .then(function(res) {
            if (res.ok) {
              showToast('success');
              waitlistForm.reset();
              useCaseSelect.classList.remove('text-accent-tertiary');
              useCaseSelect.classList.add('text-text-muted');
              otherTextarea.classList.add('hidden');
              otherTextarea.required = false;
            } else {
              showToast('error');
            }
          })
          .catch(function() {
            showToast('error');
          })
          .finally(function() {
            submitBtn.innerHTML = originalText;
            submitBtn.disabled = false;
          });
        });
      }

      // Infra pill click handler
      document.querySelectorAll('[data-infra-group]').forEach((group) => {
        group.querySelectorAll('[data-infra-option]').forEach((pill) => {
          pill.addEventListener('click', () => {
            group.querySelectorAll('[data-infra-option]').forEach((p) => {
              p.className = p.className
                .replace(/bg-accent-primary\/20/g, 'bg-white/5')
                .replace(/text-accent-tertiary/g, 'text-text-muted')
                .replace(/border-accent-primary\/30/g, 'border-white/5');
            });
            pill.className = pill.className
              .replace(/bg-white\/5/g, 'bg-accent-primary/20')
              .replace(/text-text-muted/g, 'text-accent-tertiary')
              .replace(/border-white\/5/g, 'border-accent-primary/30');
          });
        });
      });
    </script>
  </body>
</html>
